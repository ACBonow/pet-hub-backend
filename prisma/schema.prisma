generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  refreshToken String?  @map("refresh_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  emailVerified              Boolean   @default(false) @map("email_verified")
  verificationToken          String?   @map("verification_token")
  verificationTokenExpiresAt DateTime? @map("verification_token_expires_at")
  resetPasswordToken         String?   @map("reset_password_token")
  resetPasswordTokenExpiresAt DateTime? @map("reset_password_token_expires_at")

  person Person?

  @@map("users")
}

// ─── Person ──────────────────────────────────────────────────────────────────

model Person {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  name      String
  cpf       String   @unique // 11 digits, no formatting
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationsAsOwner OrganizationPerson[]
  tutoredPets          Tutorship[]            @relation("PersonTutor")
  coTutoredPets        CoTutor[]              @relation("PersonCoTutor")
  adoptionListings     AdoptionListing[]      @relation("PersonAdoption")
  lostFoundReports     LostFoundReport[]

  @@index([cpf])
  @@map("persons")
}

// ─── Organization ────────────────────────────────────────────────────────────

enum OrgType {
  COMPANY
  NGO
}

enum OrgRole {
  OWNER
  MANAGER
  MEMBER
}

model Organization {
  id                  String   @id @default(uuid())
  name                String
  type                OrgType
  cnpj                String?  @unique // 14 digits, no formatting — required for COMPANY
  description         String?
  phone               String?
  email               String?
  website             String?
  instagram           String?
  photoUrl            String?  @map("photo_url")
  address             String?  // legacy free-text
  addressStreet       String?  @map("address_street")
  addressNeighborhood String?  @map("address_neighborhood")
  addressNumber       String?  @map("address_number")
  addressCep          String?  @map("address_cep")
  addressCity         String?  @map("address_city")
  addressState        String?  @map("address_state")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  responsiblePersons OrganizationPerson[]
  tutoredPets        Tutorship[]          @relation("OrgTutor")
  coTutoredPets      CoTutor[]            @relation("OrgCoTutor")
  adoptionListings   AdoptionListing[]    @relation("OrgAdoption")
  serviceListings    ServiceListing[]
  lostFoundReports   LostFoundReport[]

  @@index([cnpj])
  @@map("organizations")
}

model OrganizationPerson {
  organizationId String   @map("organization_id")
  personId       String   @map("person_id")
  role           OrgRole  @default(MEMBER)
  assignedAt     DateTime @default(now()) @map("assigned_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([organizationId, personId])
  @@map("organization_persons")
}

// ─── Pet ─────────────────────────────────────────────────────────────────────

model Pet {
  id        String    @id @default(uuid())
  name      String
  species   String    // e.g. "Cão", "Gato", "Ave"
  breed     String?
  gender    String?
  castrated Boolean?
  birthDate DateTime? @map("birth_date")
  photoUrl  String?   @map("photo_url")
  microchip String?   @unique
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tutorships        Tutorship[]
  coTutors          CoTutor[]
  vaccinations      Vaccination[]
  examFiles         ExamFile[]
  preventiveRecords PreventiveRecord[]
  adoptionListing   AdoptionListing?
  lostFoundReports  LostFoundReport[]

  @@index([deletedAt])
  @@map("pets")
}

// ─── Tutorship ───────────────────────────────────────────────────────────────

enum TutorType {
  PERSON
  ORGANIZATION
}

enum TutorshipType {
  OWNER
  TUTOR
  TEMPORARY_HOME
}

model Tutorship {
  id             String        @id @default(uuid())
  petId          String        @map("pet_id")
  tutorType      TutorType     @map("tutor_type")
  personTutorId  String?       @map("person_tutor_id")
  orgTutorId     String?       @map("org_tutor_id")
  type           TutorshipType
  active         Boolean       @default(true)
  startDate      DateTime      @default(now()) @map("start_date")
  endDate        DateTime?     @map("end_date")
  transferNotes  String?       @map("transfer_notes")
  createdAt      DateTime      @default(now()) @map("created_at")

  pet          Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  personTutor  Person?       @relation("PersonTutor", fields: [personTutorId], references: [id])
  orgTutor     Organization? @relation("OrgTutor", fields: [orgTutorId], references: [id])

  @@index([petId, active])
  @@map("tutorships")
}

model CoTutor {
  id            String    @id @default(uuid())
  petId         String    @map("pet_id")
  tutorType     TutorType @map("tutor_type")
  personTutorId String?   @map("person_tutor_id")
  orgTutorId    String?   @map("org_tutor_id")
  assignedAt    DateTime  @default(now()) @map("assigned_at")

  pet         Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  personTutor Person?       @relation("PersonCoTutor", fields: [personTutorId], references: [id])
  orgTutor    Organization? @relation("OrgCoTutor", fields: [orgTutorId], references: [id])

  @@unique([petId, personTutorId])
  @@unique([petId, orgTutorId])
  @@map("co_tutors")
}

// ─── Adoption ────────────────────────────────────────────────────────────────

enum AdoptionStatus {
  AVAILABLE
  RESERVED
  ADOPTED
}

model AdoptionListing {
  id               String         @id @default(uuid())
  petId            String         @unique @map("pet_id")
  listenerType     TutorType      @map("listener_type") // who listed it
  personId         String?        @map("person_id")
  organizationId   String?        @map("organization_id")
  description      String?
  contactEmail     String?        @map("contact_email")
  contactPhone     String?        @map("contact_phone")
  contactWhatsapp  String?        @map("contact_whatsapp")
  status           AdoptionStatus @default(AVAILABLE)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  pet          Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  person       Person?       @relation("PersonAdoption", fields: [personId], references: [id])
  organization Organization? @relation("OrgAdoption", fields: [organizationId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("adoption_listings")
}

// ─── Lost & Found ─────────────────────────────────────────────────────────────

enum LostFoundType {
  LOST
  FOUND
}

enum LostFoundStatus {
  OPEN
  RESOLVED
}

model LostFoundReport {
  id                  String          @id @default(uuid())
  type                LostFoundType
  petId               String?         @map("pet_id")
  reporterId          String          @map("reporter_id")
  petName             String?         @map("pet_name")
  species             String?
  description         String
  location            String?         // legacy free-text field
  addressStreet       String?         @map("address_street")
  addressNeighborhood String?         @map("address_neighborhood")
  addressNumber       String?         @map("address_number")
  addressCep          String?         @map("address_cep")
  addressCity         String?         @map("address_city")
  addressState        String?         @map("address_state")
  addressNotes        String?         @map("address_notes")
  photoUrl            String?         @map("photo_url")
  contactInfo         String?         @map("contact_info")
  contactEmail        String?         @map("contact_email")
  contactPhone        String?         @map("contact_phone")
  organizationId      String?         @map("organization_id")
  status              LostFoundStatus @default(OPEN)
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  deletedAt           DateTime?       @map("deleted_at")

  pet          Pet?          @relation(fields: [petId], references: [id])
  reporter     Person        @relation(fields: [reporterId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([type, status, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("lost_found_reports")
}

// ─── Vaccine Catalog ─────────────────────────────────────────────────────────

enum PetSpecies {
  DOG
  CAT
  BIRD
  RABBIT
  OTHER
}

enum VaccineTemplateType {
  VACCINE
  PREVENTIVE
}

enum VaccineCategory {
  CORE
  NON_CORE
  LIFESTYLE
}

enum PreventiveType {
  FLEA
  TICK
  FLEA_TICK
  DEWORMER
  HEARTWORM
  OTHER
}

model VaccineTemplate {
  id                  String              @id @default(uuid())
  name                String
  slug                String              @unique
  type                VaccineTemplateType
  species             PetSpecies[]
  category            VaccineCategory
  preventiveType      PreventiveType?     @map("preventive_type")
  targetConditions    String?             @map("target_conditions")
  minimumAgeWeeks     Int                 @default(0) @map("minimum_age_weeks")
  initialDosesCount   Int                 @default(1) @map("initial_doses_count")
  initialIntervalDays Int                 @default(28) @map("initial_interval_days")
  boosterIntervalDays Int                 @default(365) @map("booster_interval_days")
  isRequiredByLaw     Boolean             @default(false) @map("is_required_by_law")
  notes               String?
  active              Boolean             @default(true)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  brands            VaccineBrand[]
  vaccinations      Vaccination[]
  preventiveRecords PreventiveRecord[]

  @@index([type, category])
  @@map("vaccine_templates")
}

model VaccineBrand {
  id           String   @id @default(uuid())
  templateId   String   @map("template_id")
  brandName    String   @map("brand_name")
  manufacturer String
  presentation String?
  sizes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  template VaccineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("vaccine_brands")
}

// ─── Pet Health ───────────────────────────────────────────────────────────────

model Vaccination {
  id               String    @id @default(uuid())
  petId            String    @map("pet_id")
  templateId       String?   @map("template_id")
  doseNumber       Int?      @map("dose_number")
  vaccineName      String    @map("vaccine_name")
  manufacturer     String?
  batchNumber      String?   @map("batch_number")
  applicationDate  DateTime  @map("application_date")
  nextDueDate      DateTime? @map("next_due_date")
  veterinarianName String?   @map("veterinarian_name")
  clinicName       String?   @map("clinic_name")
  fileUrl          String?   @map("file_url")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  pet      Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  template VaccineTemplate? @relation(fields: [templateId], references: [id])

  @@index([petId, applicationDate])
  @@index([petId, templateId])
  @@map("vaccinations")
}

model PreventiveRecord {
  id          String    @id @default(uuid())
  petId       String    @map("pet_id")
  templateId  String?   @map("template_id")
  productName String    @map("product_name")
  appliedAt   DateTime  @map("applied_at")
  nextDueDate DateTime? @map("next_due_date")
  brand       String?
  batchNumber String?   @map("batch_number")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  pet      Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  template VaccineTemplate? @relation(fields: [templateId], references: [id])

  @@index([petId, appliedAt])
  @@map("preventive_records")
}

model ExamFile {
  id        String   @id @default(uuid())
  petId     String   @map("pet_id")
  examType  String   @map("exam_type") // e.g. "Hemograma", "Raio-X", "Ultrassom"
  fileUrl   String   @map("file_url")  // Supabase Storage path
  examDate  DateTime @map("exam_date")
  labName   String?  @map("lab_name")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, examDate])
  @@map("exam_files")
}

// ─── Services Directory ───────────────────────────────────────────────────────

model ServiceType {
  id        String   @id @default(uuid())
  code      String   @unique
  label     String
  color     String   @default("bg-gray-100 text-gray-800")
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  services  ServiceListing[]

  @@map("service_types")
}

model ServiceListing {
  id                 String   @id @default(uuid())
  name               String
  serviceTypeId      String   @map("service_type_id")
  description        String?
  zipCode            String?  @map("zip_code")
  street             String?
  number             String?
  complement         String?
  neighborhood       String?
  city               String?
  state              String?
  phone              String?
  whatsapp           String?
  email              String?
  website            String?
  instagram          String?
  facebook           String?
  tiktok             String?
  youtube            String?
  googleMapsUrl      String?  @map("google_maps_url")
  googleBusinessUrl  String?  @map("google_business_url")
  organizationId     String?  @map("organization_id")
  photoUrl           String?  @map("photo_url")
  createdByUserId    String?   @map("created_by_user_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  serviceType  ServiceType    @relation(fields: [serviceTypeId], references: [id])
  organization Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([serviceTypeId])
  @@index([deletedAt])
  @@map("service_listings")
}
